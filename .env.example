# Required: Anthropic API key for font identification (Claude Opus 4.6 / Sonnet 4.6).
# Create one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Optional: override the identification model. Defaults to claude-opus-4-6.
# Set to "sonnet" to use claude-sonnet-4-6 (cheaper, slightly less accurate).
# WTF_MODEL=opus

# Rate limiting backend: "memory" | "upstash" | "off".
# - memory: in-process LRU (default for local dev + single-instance self-host).
# - upstash: distributed, required for multi-instance hosted deploys.
# - off: no limits at all (common for self-hosters).
WTF_RATELIMIT=memory

# Window + count for /api/identify. Format: <count>/<window>. Examples: 10/1h, 100/1d.
WTF_RATELIMIT_IDENTIFY=10/1h

# Window + count for /api/fonts/lookup.
WTF_RATELIMIT_LOOKUP=60/1m

# Upstash credentials (only needed when WTF_RATELIMIT=upstash).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
